{
  "name": "adventchat",
  "version": "1.0.0",
  "description": "AdventChat WordPress Plugin — build tools",
  "private": true,
  "scripts": {
    "build": "npm run build:widget && npm run build:console",
    "build:widget": "esbuild assets/src/widget/index.js --bundle --minify --outfile=assets/js/dist/widget.js --format=iife --target=es2020 && esbuild assets/src/widget/widget.css --bundle --minify --outfile=assets/css/dist/widget.css",
    "build:console": "vite build --config vite.config.ts && shx cp assets/js/dist/style.css assets/css/dist/console.css",
    "dev": "concurrently \"npm run dev:widget\" \"npm run dev:console\"",
    "dev:widget": "esbuild assets/src/widget/index.js --bundle --outfile=assets/js/dist/widget.js --format=iife --target=es2020 --watch && esbuild assets/src/widget/widget.css --bundle --outfile=assets/css/dist/widget.css --watch",
    "dev:console": "vite --config vite.config.ts",
    "lint": "eslint assets/src/ --ext .ts,.tsx,.js",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "shx": "^0.4.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  }
}
